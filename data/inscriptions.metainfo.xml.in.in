<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APP_ID@</id>
  <launchable type="desktop-id">@APP_ID@.desktop</launchable>
  <translation type="gettext">@GETTEXT_PACKAGE@</translation>
  <metadata_license>CC-BY-4.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
   <provides>
    <binary>io.github.elly_code.inscriptions</binary>
  </provides>

  <name>@APP_NAME@</name>
  <summary>Translate text elegantly</summary>
  <description>
    <p>A fast, pretty, and ready translation app using DeepL free and paid API</p>
    <p>Some points of note:</p>
      <ul>
            <li>Nimble: Paste your DeepL api key (Whichever the plan), and here you go!</li>
            <li>Thoughtful: Just what you need, out of your way and a click away</li>
            <li>Comprehensive: No scary angry dialogs - If something goes wrong, explain nicely</li>
            <li>Lean: Limiting resource usage and internet communications to the minimum</li>
            <li>Supported languages: All those available via DeepL API!</li>
      </ul>
    <p>If you like this app please do not hesitate to donate to encourage its development!</p>
    <p>Libretranslate support is considered, but a heavy time and energy investment, so may or may not happen.</p>
  </description>

  <screenshots>
    <screenshot type="default" environment="pantheon">
      <caption>Main window, showcasing a translation with the highlighting feature</caption>
      <image>https://raw.githubusercontent.com/elly-code/inscriptions/1.1.0/data/screenshots/window-light.png</image>
    </screenshot>
    <screenshot environment="pantheon:dark">
      <caption>Main window with dark theme, showcasing a translation with the highlighting feature</caption>
      <image>https://raw.githubusercontent.com/elly-code/inscriptions/1.1.0/data/screenshots/window-dark.png</image>
    </screenshot>
  </screenshots>

  <content_rating type="oars-1.1" />

  <developer id="io.github.elly_code">
    <name>Stella and Charlie!</name>
  </developer>
    <url type="homepage">https://github.com/elly-code/inscriptions</url>
    <url type="bugtracker">https://github.com/elly-code/inscriptions/issues</url>
    <url type="help">https://github.com/elly-code/inscriptions/issues</url>
    <url type="translate">https://github.com/elly-code/inscriptions/blob/main/po/README.md</url>
    <url type="donation">https://ko-fi.com/teamcons/tip</url>
    <url type="vcs-browser">https://github.com/elly-code/inscriptions</url>

  <branding>
    <color type="primary" scheme_preference="light">#3557082</color>
    <color type="primary" scheme_preference="dark">#33434e</color>
  </branding>

  <keywords>
        <keyword>Translation</keyword>
        <keyword>Translate</keyword>
        <keyword>NMT</keyword>
        <keyword>DeepL</keyword>
        <keyword>Localization</keyword>
        <keyword>Internationalization</keyword>
        <keyword>l10n</keyword>
        <keyword>i18n</keyword>
        <keyword>Localize</keyword>
        <keyword>Languages</keyword>
        <keyword>Pantheon</keyword>
        <keyword>elementary OS</keyword>
  </keywords>
  <suggests>
        <id>io.github.elly_code.jorts</id>
        <id>com.github.elfenware.badger</id>
        <id>io.github.elly_code.reminduck</id>
  </suggests>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </recommends>

  <releases>
    <release version="1.1.0" date="2026-03-16" urgency="medium">
      <description>
        <p>A polished, cleaner and better thought out UI</p>
        <ul>
            <li>New: Synchronized text zoom for both source and target, persistent, with a setting in gear menu</li>
            <li>Show/hide highlighting moved to gear menu</li>
            <li>Enable/Disable auto translation moved to gear menu</li>
            <li>Display in the language dropdown the currently selected one</li>
            <li>Greyout in the language dropdown the relevant language</li>
            <li>Switch source and language moved between both languages</li>
            <li>Static pane sizes - makes more sense, less confusing</li>
            <li>Translation button moved within the view</li>
        </ul>
      </description>
      <issues>
        <issue>Fixed: Highlighting didnt refresh correctly upon switching between light and dark theme</issue>
        <issue>Fixed: Options button had a broken fixup frame</issue>
        <issue>Fixed: Paste and clear did not interact well with undo-redo</issue>
        <issue>Fixed: On non-elementary desktops, Slate was forced upon ye. Now it should be respecting user accents</issue>
        <issue>Fixed: Some highlight toggle and options menu icon were broken. Have to force the elementary icon theme to avoid display issues</issue>
      </issues>
    </release>
    <release version="1.0.0" date="2026-02-16" urgency="medium">
      <description>
        <p>🚀 1.0.0 Initial release!</p>
        <ul>
            <li>It came to me in a dream</li>
        </ul>
        <p>😎 Guests stars:</p>
        <ul>
            <li>Amazing supercool icon designed by @wpkelso!</li>
            <li>Amazing supercool icon funded by @t3rminus!</li>
            <li>Initial Italian translation thanks to @albanobattistella!</li>
            <li>Initial Swedish translation thanks to @yeager!</li>
            <li>You, the user, for trying this supercool app!</li>
        </ul>
      </description>
    </release>
  </releases>

</component>