#: data/inscriptions.desktop.in.in:6 data/inscriptions.metainfo.xml.in.in:12
#: src/Widgets/HeaderBar.vala:66 src/Windows/MainWindow.vala:30
msgid "Inscriptions"
msgstr "Inscriptions"

#: data/inscriptions.desktop.in.in:7
msgid "Text translator"
msgstr "Prevoditelj teksta"

#: data/inscriptions.desktop.in.in:8 data/inscriptions.metainfo.xml.in.in:13
msgid "Translate text elegantly"
msgstr "Prevedi tekst na elegantan način"

#: data/inscriptions.desktop.in.in:13
msgid ""
"text;translate;translation;translator;deepl;NMT;lang;localize;l10n;i18n;"
"localization;internationalization;"
msgstr ""
"tekst;prevedi;prijevod;prevoditelj;deepl;NMT;jezik;lokalizirati;L10N;i18n;"
"lokalizacija;internacionalizacija;"

#: data/inscriptions.metainfo.xml.in.in:15
msgid "A fast, pretty, and ready translation app using DeepL free and paid API"
msgstr ""
"Brza, lijepa i spremna aplikacija za prevođenje koja koristi besplatni i "
"plaćeni DeepL API"

#: data/inscriptions.metainfo.xml.in.in:16
msgid "Some points of note:"
msgstr "Nekoliko napomena:"

#: data/inscriptions.metainfo.xml.in.in:18
msgid "Nimble: Paste your DeepL api key (Whichever the plan), and here you go!"
msgstr ""
"Brzo i jednostavno: Zalijepi svoj DeepL API ključ (bez obzira na paket) i "
"spreman/na si!"

#: data/inscriptions.metainfo.xml.in.in:19
msgid "Thoughtful: Just what you need, out of your way and a click away"
msgstr ""
"Pametno osmišljeno: Samo ono što ti treba, bez smetnji i uvijek pri ruci"

#: data/inscriptions.metainfo.xml.in.in:20
msgid ""
"Comprehensive: No scary angry dialogs - If something goes wrong, explain "
"nicely"
msgstr ""
"Bez gnjavaže: Nema strašnih upozorenja – ako se dogodi neka greška, sve će "
"biti lijepo objašnjeno"

#: data/inscriptions.metainfo.xml.in.in:21
msgid ""
"Lean: Limiting resource usage and internet communications to the minimum"
msgstr "Lagano: Minimalna potrošnja resursa i internetske komunikacije"

#: data/inscriptions.metainfo.xml.in.in:22
msgid "Supported languages: All those available via DeepL API!"
msgstr "Podržani jezici: Svi jezici koji su dostupni putem DeepL API-a!"

#: data/inscriptions.metainfo.xml.in.in:24
msgid ""
"If you like this app please do not hesitate to donate to encourage its "
"development!"
msgstr "Ako ti se aplikacija sviđa, slobodno doniraj i podrži daljnji razvoj!"

#: data/inscriptions.metainfo.xml.in.in:25
msgid ""
"Libretranslate support is considered, but a heavy time and energy "
"investment, so may or may not happen."
msgstr ""
"Podrška za LibreTranslate je u planu, ali zahtijeva puno vremena i truda, "
"stoga možda uspije, možda i ne."

#: data/inscriptions.metainfo.xml.in.in:30
msgid "Main window, showcasing a translation with the highlighting feature"
msgstr "Glavni prozor koji prikazuje prijevod s funkcijom isticanja"

#: data/inscriptions.metainfo.xml.in.in:34
msgid ""
"Main window with dark theme, showcasing a translation with the highlighting "
"feature"
msgstr ""
"Glavni prozor u tamnoj temi koji prikazuje prijevod s funkcijom isticanja"

#: data/inscriptions.metainfo.xml.in.in:38
msgid ""
"You can change view to be stacked vertically. Whichever is more convenient "
"for you!"
msgstr ""
"Prikaz možeš prebaciti i na okomiti prikaz ploča – kako god ti bolje "
"odgovara!"

#: data/inscriptions.metainfo.xml.in.in:42
msgid ""
"A comprehensive setup screen, aiding you to get started as best the "
"developer can think of"
msgstr "Detaljan ekran za postavljanje koji pomaže da što lakše započneš"

#: data/inscriptions.metainfo.xml.in.in:46
msgid ""
"Comprehensive error screen, which neither goes into techno babble, nor hides "
"it from you"
msgstr ""
"Detaljan prikaz greške koji ne priča nerazumljivim tehničkim jezikom, ali "
"ništa ni ne skriva"

#: data/inscriptions.metainfo.xml.in.in:50
msgid ""
"Unhandled errors to report? Curious what goes behind the screen? Or just "
"want to feel cool? You can access logs via ctrl+alt+shift"
msgstr ""
"Imaš grešku za prijaviti? Zanima te što se događa iza kulisa? Ili se samo "
"želiš osjećati cool? Logovima možeš pristupiti putem tipki ctrl+alt+shift"

#: data/inscriptions.metainfo.xml.in.in:58
msgid "Stella and Charlie!"
msgstr "Stella i Charlie!"

